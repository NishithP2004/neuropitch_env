# Required credentials
OPENAI_API_KEY=your_openai_api_key
TAVILY_API_KEY=your_tavily_api_key

# Hugging Face token — needed to push fine-tuned model to Hub
# Get yours at https://huggingface.co/settings/tokens (write access)
HF_TOKEN=hf_your_token_here

# Compliance mediator
OPENAI_MEDIATOR_MODEL=gpt-5.1

# Ollama runtime
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODELS=/data/ollama/models

# TRIBE v2 runtime
TRIBE_MODEL_ID=facebook/tribev2
TRIBE_CACHE_DIR=/data/tribe-cache
TRIBE_AUDIO_ANCHOR_PATH=./server/reference.wav

# Environment controls
NEUROPITCH_WORD_LIMIT=120
